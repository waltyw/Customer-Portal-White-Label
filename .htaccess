RewriteEngine On
RewriteBase /

# Block direct browser access to private directories
RewriteRule ^(config|src|templates|vendor-standalone|storage)(/|$) - [F,L]

# Serve real files and directories as-is (css, js, images etc)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through index.php
RewriteRule ^ index.php [QSA,L]
