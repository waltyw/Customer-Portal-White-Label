# Copy this to .env and fill in your values
# NEVER commit .env to version control

APP_NAME="Beebizzi Customer Portal"
APP_URL=https://customer-portal.beebizzi.co.uk
APP_ENV=production
APP_DEBUG=false

# Database
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# SMTP Email
SMTP_HOST=mail.beebizzi.co.uk
SMTP_PORT=587
SMTP_USER=noreply@beebizzi.co.uk
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME="Beebizzi Support"
SMTP_FROM_EMAIL=noreply@beebizzi.co.uk

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Bank Transfer Details (shown to customers as alternative)
BANK_NAME="Your Bank Name"
BANK_ACCOUNT_NAME="Beebizzi Ltd"
BANK_SORT_CODE=00-00-00
BANK_ACCOUNT_NUMBER=00000000
BANK_REFERENCE_PREFIX=BBZ

# Session
SESSION_NAME=bbz_portal
SESSION_LIFETIME=7200

# Security
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=generate_a_random_32_byte_hex_key_here
